# Local development — used with docker-compose.dev.yml, which ignores
# BUILD_CONFIGURATION (the dev stage runs `nx serve`, not a configured
# build) but still reads the port and image-pin variables below.

BUILD_CONFIGURATION=development

CUSTOMER_APP_PORT=4200
RESTAURANT_APP_PORT=4201
ADMIN_APP_PORT=4202
DELIVERY_APP_PORT=4203

NODE_VERSION=24-alpine
NGINX_VERSION=1.27-alpine

IMAGE_REGISTRY=local
IMAGE_TAG=dev
