# Staging — bakes each app's environment.staging.ts (apps/*/project.json
# already defines a `staging` build configuration with its own
# fileReplacement; see e.g. apps/customer-app/src/environments/environment.staging.ts).

BUILD_CONFIGURATION=staging

CUSTOMER_APP_PORT=4200
RESTAURANT_APP_PORT=4201
ADMIN_APP_PORT=4202
DELIVERY_APP_PORT=4203

NODE_VERSION=24-alpine
NGINX_VERSION=1.27-alpine

IMAGE_REGISTRY=ghcr.io/patheya-express
IMAGE_TAG=staging
