# Infrastructure-level environment variables — these drive Docker/Compose/CI
# (host port mappings, which Angular build configuration to bake into an
# image, base image versions). They are NOT the same thing as each app's
# apps/*/src/environments/environment*.ts files, which are Angular's own
# build-time configuration (apiBaseUrl, socketUrl, map/payment keys) selected
# by BUILD_CONFIGURATION below via Angular's existing fileReplacements — this
# file never duplicates or overrides those values.
#
# Copy to a sibling .env file per environment (see .env.development,
# .env.staging, .env.production in this directory for filled-in examples)
# and pass it to compose with `--env-file`. Nothing in this file is a
# secret — see infrastructure/docs/secrets-guide.md for why this frontend
# has none to manage, and how CI/registry credentials are handled instead.

# --- Which Angular build configuration to bake into each image ---
# Must match a configuration already defined in apps/*/project.json
# (development | staging | production). Selects apiBaseUrl/socketUrl/keys
# via Angular's existing environment.*.ts file replacement.
BUILD_CONFIGURATION=production

# --- Host port mappings (docker-compose.yml) ---
CUSTOMER_APP_PORT=4200
RESTAURANT_APP_PORT=4201
ADMIN_APP_PORT=4202
DELIVERY_APP_PORT=4203

# --- Base image pins (infrastructure/docker/frontend.Dockerfile build args) ---
NODE_VERSION=24-alpine
NGINX_VERSION=1.27-alpine

# --- Image tagging (used by CI and infrastructure/scripts/docker-build.sh) ---
IMAGE_REGISTRY=ghcr.io/patheya-express
IMAGE_TAG=local
