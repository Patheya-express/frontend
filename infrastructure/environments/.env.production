# Production — bakes each app's environment.prod.ts. Host port variables
# below are only relevant to the single-host docker-compose.prod.yml path;
# the Kubernetes deployment (infrastructure/kubernetes) uses Service/Ingress
# routing instead and ignores these.

BUILD_CONFIGURATION=production

CUSTOMER_APP_PORT=4200
RESTAURANT_APP_PORT=4201
ADMIN_APP_PORT=4202
DELIVERY_APP_PORT=4203

NODE_VERSION=24-alpine
NGINX_VERSION=1.27-alpine

IMAGE_REGISTRY=ghcr.io/patheya-express
IMAGE_TAG=latest
