{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": ["google.maps"]
  },
  "exclude": [
    "**/*.spec.ts",
    "**/*.test.ts",
