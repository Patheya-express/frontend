# Normalize line endings for everyone regardless of OS/editor — this repo
# is developed on Windows (see infrastructure/scripts, written as .sh for
# Git Bash/CI/Linux containers) so LF must be enforced explicitly rather
# than left to core.autocrlf.
* text=auto eol=lf

*.sh text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Keep binary assets untouched by line-ending normalization / diffing.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
